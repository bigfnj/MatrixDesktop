<Project>
  <PropertyGroup>
    <!--
      EXPERIMENTAL: smaller self-contained output using IL trimming.

      WinForms + WebView2 are generally safe here, but trimming can break apps that rely on
      reflection/COM activation in unexpected ways. Validate on your target machines.

      Produces: <solutionRoot>\publish\win-x64-trimmed\
    -->
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <TargetFramework>net10.0-windows</TargetFramework>

    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>

    <PublishSingleFile>false</PublishSingleFile>

    <PublishTrimmed>true</PublishTrimmed>
    <TrimMode>full</TrimMode>

    <InvariantGlobalization>true</InvariantGlobalization>

    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>

    <PublishDir>$(MSBuildProjectDirectory)\..\publish\win-x64-trimmed\</PublishDir>
  </PropertyGroup>
</Project>

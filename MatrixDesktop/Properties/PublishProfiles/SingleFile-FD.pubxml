<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish Profile: Single File Executable (Framework-Dependent)
  
  Creates a single-file executable with:
  - All managed assemblies bundled into MatrixDesktop.exe
  - Web content copied to 'web' folder (required for app to function)
  - WebView2 native dependencies handled properly
  
  Usage:
    - Visual Studio: Build > Publish Selection > SingleFile-FD
    - CLI: dotnet publish -c Release -p:PublishProfile=SingleFile-FD
  
  Output structure:
    publish\
    ├── MatrixDesktop.exe       (single file, all managed code bundled)
    ├── web\                    (content files - required for app)
    │   ├── index.html
    │   ├── js\
    │   ├── assets\
    │   └── ...
    └── runtimes\               (WebView2 native dependencies)
        └── win-x64\native\
            └── WebView2Loader.dll  (required native component)
-->
<Project>
  <PropertyGroup>
    <!-- Framework-dependent deployment (requires .NET 10 Runtime) -->
    <SelfContained>false</SelfContained>
    
    <!-- Single file executable - bundles all managed assemblies -->
    <PublishSingleFile>true</PublishSingleFile>
    
    <!-- Windows x64 target -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    
    <!-- Release configuration -->
    <Configuration>Release</Configuration>
    
    <!-- Target framework -->
    <TargetFramework>net10.0-windows</TargetFramework>
    
    <!-- No debug symbols in publish -->
    <DebugSymbols>false</DebugSymbols>
    <DebugType>None</DebugType>
    
    <!-- Don't trim - WebView2 + WinForms doesn't play well with trimming -->
    <PublishTrimmed>false</PublishTrimmed>
    
    <!-- ReadyToRun for faster startup -->
    <PublishReadyToRun>true</PublishReadyToRun>
    
    <!-- Include native libraries in single file where possible -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    
    <!-- Exclude native libraries that must remain separate (WebView2Loader) -->
    <IncludeNativeLibrariesForSelfExtract Condition="%(Filename) == 'WebView2Loader'">false</IncludeNativeLibrariesForSelfExtract>
    
    <!-- Compress bundled assemblies to reduce size -->
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    
    <!-- Don't generate extra files -->
    <GenerateRuntimeConfigurationFiles>false</GenerateRuntimeConfigurationFiles>
    <GenerateDependencyFile>false</GenerateDependencyFile>
    
    <!-- Publish directory -->
    <PublishDir>bin\Release\publish\singlefile-fd\</PublishDir>
    
    <!-- Clean publish directory -->
    <DeleteExistingFiles>true</DeleteExistingFiles>
  </PropertyGroup>
  
  <!-- 
    Note on output files:
    - MatrixDesktop.exe: Single-file bundle containing all managed assemblies
    - web\ folder: Required content files (HTML, JS, assets, shaders)
    - WebView2Loader.dll: Native dependency required by WebView2 (cannot be bundled)
  -->
</Project>
